RERANKER_MODEL_PATH=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=16

EMBEDDING_MODEL_PATH=BAAI/bge-small-zh-v1.5
LLM_MODEL_PATH=./models/Qwen2.5-7B-Int4

DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=

MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
# MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION_NAME=finance_regulations
MILVUS_EMBED_DIM=512
# MILVUS_DB_NAME=default
# MILVUS_USER=
# MILVUS_PASSWORD=

# LibreOffice（convert_testfiles.py 可选）
# SOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe

# OCR（PDF 文本层不足时自动回退）
# OCR_BACKEND=auto              # auto | docling | paddleocr | none
# OCR_LANG=ch
# OCR_MIN_TEXT_CHARS=80
# OCR_EMPTY_PAGE_RATIO=0.5
# OCR_RENDER_SCALE=2.0

# 图片预处理（低质量手机照片可增强OCR效果）
# IMAGE_PREPROCESS=auto         # auto | always | never

# Elasticsearch 全文检索
ES_HOST=127.0.0.1
ES_PORT=9200
ES_SCHEME=http
ES_INDEX_NAME=finance_regulations
ES_USERNAME=
ES_PASSWORD=
ES_ANALYZER=standard

# Neo4j 知识图谱
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j
NEO4J_DATABASE=neo4j

RETRIEVER_TOP_K=10
RERANKER_TOP_N=5
CHUNK_SIZE=512
CHUNK_OVERLAP=100
